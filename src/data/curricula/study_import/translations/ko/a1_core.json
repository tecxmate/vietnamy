    "L_092d78f5ff": {
      "W_21d5114b": "(문장 끝 존경 표시)",
      "S_255241a6": "오빠/형, 안녕하세요! (정중)",
      "S_0bd43df9": "감사합니다. (정중)",
      "S_8b9a3992": "네. (아주 정중)",
